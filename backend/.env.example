# ─────────────────────────────────────────────────────────────
# QPilot AI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# App
APP_NAME=QPilot AI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production

# Database
DATABASE_URL=postgresql+asyncpg://qpilot:qpilot_pass@localhost:5432/qpilot_db

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.3

# Jira
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=QP

# GitHub
GITHUB_TOKEN=ghp_your-github-token
GITHUB_OWNER=your-github-username
GITHUB_REPO=qpilot-automation-scripts

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# n8n
N8N_WEBHOOK_BASE_URL=http://localhost:5678/webhook

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
