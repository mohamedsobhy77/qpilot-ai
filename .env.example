# =============================================================
# QPilot AI — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# --- App ---
APP_ENV=development
APP_NAME=QPilot AI
APP_VERSION=1.0.0

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true

# --- Database ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=qpilot
POSTGRES_USER=qpilot_user
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql+asyncpg://qpilot_user:changeme_strong_password@db:5432/qpilot

# --- Authentication ---
JWT_SECRET=change_this_to_a_long_random_secret_string_minimum_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.2

# --- Jira ---
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_PROJECT_KEY=QA
JIRA_USER_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token

# --- GitHub ---
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=qpilot-automation-scripts
GITHUB_DEFAULT_BRANCH=main

# --- Slack ---
SLACK_WEBHOOK_URL=your-slack-webhook-url
SLACK_CHANNEL=#qa-automation
SLACK_BOT_TOKEN=xoxb-your-bot-token

# --- n8n ---
N8N_WEBHOOK_BASE_URL=http://n8n:5678
N8N_WORKFLOW_REQUIREMENT_WEBHOOK=/webhook/requirement-submitted
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=QPilot AI

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
