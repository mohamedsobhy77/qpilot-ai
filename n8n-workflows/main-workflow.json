{
  "name": "QPilot AI — Main QA Workflow",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "qpilot/requirement",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook: Requirement Submitted",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [240, 300],
      "webhookId": "qpilot-requirement-webhook"
    },
    {
      "parameters": {
        "conditions": {
          "options": {"caseSensitive": true, "leftValue": "", "typeValidation": "strict"},
          "conditions": [
            {
              "leftValue": "={{ $json.body.title }}",
              "rightValue": "",
              "operator": {"type": "string", "operation": "notEmpty"}
            },
            {
              "leftValue": "={{ $json.body.description }}",
              "rightValue": "",
              "operator": {"type": "string", "operation": "notEmpty"}
            }
          ],
          "combinator": "and"
        }
      },
      "id": "validate-input",
      "name": "Validate: Check Required Fields",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/api/v1/requirements",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Authorization", "value": "={{ 'Bearer ' + $env.BACKEND_JWT_TOKEN }}"},
            {"name": "Content-Type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "title", "value": "={{ $json.body.title }}"},
            {"name": "description", "value": "={{ $json.body.description }}"}
          ]
        },
        "options": {"response": {"response": {"responseFormat": "json"}}}
      },
      "id": "create-requirement",
      "name": "API: Create & Analyze Requirement",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/api/v1/scenarios/generate",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Authorization", "value": "={{ 'Bearer ' + $env.BACKEND_JWT_TOKEN }}"},
            {"name": "Content-Type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "requirement_id", "value": "={{ $json.data.id }}"}
          ]
        },
        "options": {}
      },
      "id": "generate-scenarios",
      "name": "API: Generate Test Scenarios",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [900, 220]
    },
    {
      "parameters": {
        "fieldToSplitOut": "data.scenarios",
        "options": {}
      },
      "id": "split-scenarios",
      "name": "Split: One Item per Scenario",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [1120, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/api/v1/test-cases/generate",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Authorization", "value": "={{ 'Bearer ' + $env.BACKEND_JWT_TOKEN }}"},
            {"name": "Content-Type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "scenario_id", "value": "={{ $json.id }}"}
          ]
        },
        "options": {}
      },
      "id": "generate-test-cases",
      "name": "API: Generate Test Cases (per scenario)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1340, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/api/v1/integrations/jira/create",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Authorization", "value": "={{ 'Bearer ' + $env.BACKEND_JWT_TOKEN }}"},
            {"name": "Content-Type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"related_entity_id\": \"{{ $('split-scenarios').item.json.id }}\",\n  \"issue_type\": \"Task\",\n  \"summary\": \"[QPilot] {{ $('split-scenarios').item.json.scenario_title }}\",\n  \"description\": \"Auto-generated by QPilot AI.\\n\\nScenario: {{ $('split-scenarios').item.json.scenario_description }}\"\n}",
        "options": {}
      },
      "id": "create-jira-ticket",
      "name": "API: Create Jira Ticket",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 220]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.BACKEND_URL }}/api/v1/integrations/slack/notify",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "Authorization", "value": "={{ 'Bearer ' + $env.BACKEND_JWT_TOKEN }}"},
            {"name": "Content-Type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "message",
              "value": "=✅ QPilot AI: Workflow completed for requirement '{{ $('create-requirement').item.json.data.title }}'. Scenarios and test cases have been generated and Jira tickets created."
            }
          ]
        },
        "options": {}
      },
      "id": "slack-notification",
      "name": "API: Send Slack Notification",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1780, 220]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"success\": false, \"message\": \"Validation failed: title and description are required.\"}",
        "options": {"responseCode": 422}
      },
      "id": "validation-error-response",
      "name": "Response: Validation Error",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [680, 400]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={\"success\": true, \"message\": \"QPilot workflow completed successfully.\", \"requirement_id\": \"{{ $('create-requirement').item.json.data.id }}\"}",
        "options": {"responseCode": 200}
      },
      "id": "success-response",
      "name": "Response: Workflow Complete",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [2000, 220]
    }
  ],
